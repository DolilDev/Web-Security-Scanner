# Backend database
DATABASE_URL=postgresql+asyncpg://websec:websec@postgres:5432/websec

# Redis for Celery
REDIS_URL=redis://redis:6379/0

# FastAPI
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Celery
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Security scan defaults
SCAN_CONCURRENCY=10
SCAN_RATE_LIMIT_MS=200
